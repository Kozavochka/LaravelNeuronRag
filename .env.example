APP_NAME="Laravel RAG"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5433
DB_DATABASE=rag_db
DB_USERNAME=rag_user
DB_PASSWORD=rag_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

OLLAMA_BASE_URL=http://127.0.0.1:11434

RAG_DOCUMENTS_DISK=local
RAG_DOCUMENTS_DIRECTORY=rag/documents
RAG_MAX_UPLOAD_KB=10240
RAG_MARKITDOWN_ENABLED=true
RAG_MARKITDOWN_BASE_URL=http://localhost
RAG_MARKITDOWN_PORT=8123
RAG_MARKITDOWN_TIMEOUT=30
RAG_MARKITDOWN_HEALTH_TTL=30
RAG_MARKITDOWN_EXTENSIONS=pdf,xlsx,xls,html,htm,jpg,jpeg,png,webp

RAG_EMBEDDING_PROVIDER=openrouter
RAG_EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
RAG_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-vl-1b-v2:free
RAG_EMBEDDING_DIMENSIONS=1024
RAG_EMBEDDING_TIMEOUT=60

RAG_LLM_PROVIDER=openrouter
RAG_LLM_TIMEOUT=90

OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openrouter/free
OPENROUTER_SITE_URL=http://localhost
OPENROUTER_APP_NAME="Laravel RAG"

RAG_CHUNK_SIZE_CHARS=3200
RAG_CHUNK_OVERLAP_CHARS=500
RAG_MIN_CHUNK_CHARS=200
RAG_MAX_CHUNKS_PER_DOCUMENT=500
RAG_STRIP_HTML_COMMENTS=true
RAG_PRESERVE_HEADINGS=true

RAG_TOP_K=8
RAG_MAX_CONTEXT_CHARS=16000
RAG_MIN_SCORE=0.0
RAG_DOCUMENT_FILTER_ENABLED=true

RAG_API_PER_PAGE=15
RAG_API_MAX_PER_PAGE=100
RAG_RUNTIME_AVAILABLE=false

VITE_APP_NAME="${APP_NAME}"
